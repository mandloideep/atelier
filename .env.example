# ── Provider selection ────────────────────────────────────────────────────────
# Defaults are tuned for the free public demo. Override to use OpenAI locally.
LLM_PROVIDER=gemini            # gemini | openai
EMBED_PROVIDER=gemini          # gemini | openai

# ── Gemini (free tier; do NOT enable billing on this Google AI project) ──────
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_LLM_MODEL=gemini-3.1-flash-lite
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_EMBED_DIM=768

# ── OpenAI (only used when LLM_PROVIDER=openai or EMBED_PROVIDER=openai) ─────
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-5-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# ── Demo guardrails ──────────────────────────────────────────────────────────
DEMO_MODE=1                    # 1 = show banner + enforce caps
SESSION_MESSAGE_CAP=5          # per browser session (incognito-bypassable)
DAILY_IP_CAP=20                # per source IP per day (persisted in usage.db; survives incognito)
CONTACT_EMAIL=
DEMO_PRELOAD_DIR=              # absolute path; e.g. /app/documents in container

# ── Required regardless of provider ──────────────────────────────────────────
TAVILY_API_KEY=
QDRANT_URL=
QDRANT_API_KEY=

# ── State paths (defaults work for local dev) ────────────────────────────────
ATELIER_SESSIONS_FILE=./sessions.json
ATELIER_CHECKPOINTS_DB=./checkpoints.db

# ── Transcript (in-memory agent-trace store) ─────────────────────────────────
TRANSCRIPT_ENABLED=1               # 0 disables capture entirely
TRANSCRIPT_MAX_SESSIONS=50         # LRU cap on distinct sessions kept in memory
TRANSCRIPT_MAX_EVENTS_PER_SESSION=500  # per-session ring buffer
TRANSCRIPT_TTL_HOURS=24            # sessions untouched longer than this drop on next write
TRANSCRIPT_MEMORY_THRESHOLD_PCT=80 # if RSS exceeds this % of cgroup limit, evict oldest 50%

# ── Evals page (ad-hoc run on the current session) ───────────────────────────
EVAL_AD_HOC_ENABLED=1              # 0 hides the "Run on this session" button
EVAL_AD_HOC_MAX_TURNS=3            # max recent turns scored per run
EVAL_AD_HOC_DAILY_IP_CAP=2         # per-IP daily cap on ad-hoc eval runs
EVAL_METRIC_MODEL=gemini-2.5-flash # Gemini model used by the DeepEval judge (needs GEMINI_API_KEY)
